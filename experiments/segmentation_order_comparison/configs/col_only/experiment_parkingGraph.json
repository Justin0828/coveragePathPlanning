{
  "experiment_name": "parkingGraph",
  "random_seed": 42,
  "robot_config": "experiments/configs/robot_config_default.json",
  "map": {
    "path": "experiments/segmentation_order_comparison/maps/parkingGraph.png",
    "pixel_size": 0.5
  },
  "segmentation": {
    "grid_size": 1,
    "min_edge_length": 2.5,
    "alpha": 0.5,
    "beta": 2.0,
    "candidate_top_k": 20,
    "candidate_scan_strategy": "col_only"
  },
  "traversal": {"start_rect": null},
  "rendering": {
    "sample_rate": 2.0,
    "colors": {
      "coverage": [30, 144, 255],
      "trail": [255, 196, 0],
      "robot": [220, 40, 40]
    }
  },
  "outputs": {
    "directory": "experiments/segmentation_order_comparison/results/parkingGraph/col_only",
    "metrics_json": "metrics.json",
    "config_snapshot": "config_snapshot.json",
    "segmentation_image": "segmentation.png",
    "traversal_image": "traversal_order.png",
    "coverage_video": "coverage.mp4",
    "coverage_image": "coverage_final.png"
  }
}
